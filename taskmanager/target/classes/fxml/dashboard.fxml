<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.taskmanager.controllers.DashboardController">
    
    <!-- Top: Barre de navigation -->
    <top>
        <VBox>
            <!-- Barre de navigation principale -->
            <ToolBar style="-fx-background-color: #2196F3;">
                <Label text="📋 Gestionnaire de Tâches" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="welcomeLabel" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                <Button text="Déconnexion" onAction="#handleLogout" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: white; -fx-border-radius: 5;"/>
            </ToolBar>
            
            <!-- Barre de recherche et filtres -->
            <VBox style="-fx-background-color: #f5f5f5;" spacing="10">
                <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                </padding>
                
                <!-- Barre de recherche -->
                <HBox spacing="10">
                    <TextField fx:id="searchField" promptText="Rechercher une tâche..." HBox.hgrow="ALWAYS"/>
                </HBox>
                
                <!-- Filtres -->
                <GridPane hgap="10" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" minWidth="80"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="150"/>
                        <ColumnConstraints halignment="RIGHT" minWidth="80"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="150"/>
                    </columnConstraints>
                    
                    <Label text="Statut:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="statusFilter" promptText="Tous" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    
                    <Label text="Priorité:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                    <ComboBox fx:id="priorityFilter" promptText="Toutes" GridPane.rowIndex="0" GridPane.columnIndex="3"/>
                    
                    <Label text="Catégorie:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="categoryFilter" promptText="Toutes" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                    
                    <Label text="Date échéance:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                    <DatePicker fx:id="dueDateFilter" promptText="Sélectionner" GridPane.rowIndex="1" GridPane.columnIndex="3"/>
                </GridPane>
                
                <!-- Bouton effacer filtres -->
                <HBox alignment="CENTER_RIGHT">
                    <Button fx:id="clearFiltersButton" text="Effacer les filtres" onAction="#clearFilters" 
                            style="-fx-background-color: #9e9e9e; -fx-text-fill: white;"/>
                </HBox>
            </VBox>
        </VBox>
    </top>
    
    <!-- Center: Contenu principal -->
    <center>
        <SplitPane orientation="HORIZONTAL" dividerPositions="0.3">
            <!-- Panneau gauche: Statistiques -->
            <VBox spacing="15" style="-fx-background-color: white;" prefWidth="250">
                <padding>
                    <Insets top="20" right="15" bottom="20" left="15"/>
                </padding>
                
                <Label text="Tableau de bord" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                
                <!-- Cartes statistiques -->
                <GridPane hgap="10" vgap="15">
                    <Label text="Total tâches:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <Label fx:id="totalTasksLabel" text="0" style="-fx-font-weight: bold; -fx-font-size: 16px;" 
                           GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    
                    <Label text="En retard:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <Label fx:id="overdueTasksLabel" text="0" style="-fx-font-weight: bold; -fx-text-fill: #c62828;" 
                           GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                    
                    <Label text="Aujourd'hui:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <Label fx:id="todayTasksLabel" text="0" style="-fx-font-weight: bold; -fx-text-fill: #2196F3;" 
                           GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                    
                    <Label text="Haute priorité:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <Label fx:id="highPriorityLabel" text="0" style="-fx-font-weight: bold; -fx-text-fill: #ef6c00;" 
                           GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                </GridPane>
                
                <Separator/>
                
                <!-- Graphique -->
                <Label text="Répartition des tâches" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                <PieChart fx:id="statusPieChart" prefHeight="200" legendVisible="false" 
                         labelsVisible="true" animated="true"/>
                
                <!-- Bouton ajouter -->
                <Button text="+ Nouvelle tâche" onAction="#handleAddTask" maxWidth="Infinity"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px;" 
                        prefHeight="40"/>
            </VBox>
            
            <!-- Panneau droit: Liste des tâches -->
            <VBox spacing="10" style="-fx-background-color: white;">
                <padding>
                    <Insets top="20" right="15" bottom="20" left="15"/>
                </padding>
                
                <!-- En-tête avec options de vue -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Mes tâches" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <ToggleButton fx:id="tableViewToggle" text="📋 Tableau" selected="true"/>
                    <ToggleButton fx:id="cardViewToggle" text="🃏 Cartes"/>
                </HBox>
                
                <!-- Conteneur pour les vues -->
                <StackPane fx:id="viewContainer" VBox.vgrow="ALWAYS"/>
            </VBox>
        </SplitPane>
    </center>
    
    <!-- Bottom: Pagination (optionnel) -->
    <bottom>
        <HBox alignment="CENTER" spacing="5" style="-fx-background-color: #f5f5f5;" 
              prefHeight="40">
            <padding>
                <Insets left="15" right="15"/>
            </padding>
            <Label text="Page 1 sur 1" style="-fx-text-fill: #666;"/>
        </HBox>
    </bottom>
</BorderPane>