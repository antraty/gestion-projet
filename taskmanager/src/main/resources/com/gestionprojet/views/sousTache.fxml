<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" xmlns:fx="http://javafx.com/fxml" 
      fx:controller="com.gestionprojet.controllers.SousTacheController"
      stylesheets="@../styles/style.css"
      prefWidth="400" prefHeight="300">
    
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    
    <Label text="Sous-tâches" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
    
    <TableView fx:id="sousTachesTableView" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="termineeColumn" text="✓" prefWidth="40"/>
            <TableColumn fx:id="titreColumn" text="Titre" prefWidth="300"/>
        </columns>
    </TableView>
    
    <HBox spacing="10">
        <TextField fx:id="nouveauTitreField" promptText="Nouvelle sous-tâche" HBox.hgrow="ALWAYS"/>
        <Button text="Ajouter" onAction="#handleAjouterSousTache" styleClass="primary-button"/>
        <Button text="Supprimer" onAction="#handleSupprimerSousTache" styleClass="danger-button"/>
    </HBox>
</VBox>